# Copy to .env and adjust. Used by docker-compose.

# --- Database (official postgres image variables) ---
# These initialise the postgres container on first boot.
POSTGRES_DB=crypto_analytics
POSTGRES_USER=db_user
POSTGRES_PASSWORD=changeme

# Connection string consumed by the Python services (engine / api / bot).
# The host MUST match the compose service name (crypto-db). The "+asyncpg"
# driver suffix is normalised automatically by the backend, and keep these
# credentials in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql+asyncpg://db_user:changeme@crypto-db:5432/crypto_analytics

# --- Telegram bot (required for the bot + alerts) ---
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Telegram user ids (comma separated) allowed to manage the symbol blacklist.
# These users can run /blacklist ADD|REMOVE|LIST and get an inline
# "🚫 Blacklist" button on every alert. Find your id via @userinfobot.
TELEGRAM_ADMIN_IDS=

# --- Engine tuning ---
ARB_POLL_INTERVAL=30
ARB_MIN_RAW_SPREAD=0.2

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- API CORS ---
CORS_ORIGINS=*
